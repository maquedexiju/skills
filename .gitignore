# ========== Strategy: Exclude all folders, only include specified 5 ==========

# First, exclude ALL directories
*/

# Then explicitly include the 6 skills we want
!siyuan/
!siyuan/**/
!vikunja/
!vikunja/**/
!memos/
!memos/**/
!business-card-skill/
!business-card-skill/**/
!market-correlations/
!market-correlations/**/
!freshrss-filter/
!freshrss-filter/**/

# Include .gitignore itself
!.gitignore

# ========== Sensitive Configuration Files (within included folders) ==========
# API tokens, passwords, credentials
siyuan/config.json
vikunja/config.json
memos/config.json
freshrss-filter/config.json
